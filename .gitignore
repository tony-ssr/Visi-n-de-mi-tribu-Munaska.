# .gitignore — Visión Munaska

# ─── Sistema operativo ──────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editores ───────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Credenciales locales (¡nunca subir!) ─
# Si guardas tus keys en un archivo separado:
.env
.env.local
secrets.js
config.local.js

# ─── Node (si algún día usas herramientas de build) ─
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Builds ─────────────────────────────
dist/
build/
